  56:Application/Src/IMU_Task.c ****  * 模块内部状态变量
  57:Application/Src/IMU_Task.c ****  *============================================================================*/
  58:Application/Src/IMU_Task.c **** uint8_t Init_Status = Gyro_Init_Flag;   /**< 陀螺仪校准状态，初值为"校准中" */
  59:Application/Src/IMU_Task.c **** 
  60:Application/Src/IMU_Task.c **** /**
  61:Application/Src/IMU_Task.c ****  *******************************************************************************
  62:Application/Src/IMU_Task.c ****  * @brief       IMU_Task - IMU主任务（RTOS线程入口）
  63:Application/Src/IMU_Task.c ****  * @param       argument  RTOS线程参数（未使用）
  64:Application/Src/IMU_Task.c ****  * @retval      void
  65:Application/Src/IMU_Task.c ****  * @details     上电初始化后以1kHz频率循环执行温控、零偏校准和姿态解算。
  66:Application/Src/IMU_Task.c ****  *              校准完成后（~1秒）姿态角开始正常输出。
  67:Application/Src/IMU_Task.c ****  *******************************************************************************
  68:Application/Src/IMU_Task.c ****  */
  69:Application/Src/IMU_Task.c **** void IMU_Task(void *argument)
  70:Application/Src/IMU_Task.c **** {
  71:Application/Src/IMU_Task.c ****     IMU_Init();                             /* 传感器及外设初始化              */
  72:Application/Src/IMU_Task.c ****     while (1)
  73:Application/Src/IMU_Task.c ****     {
  74:Application/Src/IMU_Task.c ****         osDelay(1);                         /* 1ms 周期 = 1kHz 控制/解算频率  */
  75:Application/Src/IMU_Task.c ****         IMU_temp_Ctrl();                    /* 温度PID控制（内部300ms分频）    */
  76:Application/Src/IMU_Task.c ****         Gyro_Init(&Init_Status);            /* 陀螺仪零偏校准状态机           */
  77:Application/Src/IMU_Task.c ****         IMU_Data_Read();                    /* 读取传感器 + Mahony姿态解算    */
  78:Application/Src/IMU_Task.c ****     }
  79:Application/Src/IMU_Task.c **** }
  80:Application/Src/IMU_Task.c **** 
  81:Application/Src/IMU_Task.c **** /**
  82:Application/Src/IMU_Task.c ****  *******************************************************************************
  83:Application/Src/IMU_Task.c ****  * @brief       IMU_Init - IMU系统初始化
  84:Application/Src/IMU_Task.c ****  * @param       void
  85:Application/Src/IMU_Task.c ****  * @retval      void
  86:Application/Src/IMU_Task.c ****  * @details     执行以下初始化步骤：
  87:Application/Src/IMU_Task.c ****  *              1. 初始化温度PID控制器（位置式PID）
  88:Application/Src/IMU_Task.c ****  *              2. 启动TIM3 CH4 PWM输出（加热元件驱动）
ARM GAS  C:\Users\11464\AppData\Local\Temp\ccbN37mA.s 			page 3


  89:Application/Src/IMU_Task.c ****  *              3. 等待2秒让BMI088传感器内部上电稳定
  90:Application/Src/IMU_Task.c ****  *              4. 配置Mahony滤波器采样频率为1kHz
  91:Application/Src/IMU_Task.c ****  *              5. 检测BMI088在线状态，若离线则循环重试（间隔1秒）
  92:Application/Src/IMU_Task.c ****  *******************************************************************************
  93:Application/Src/IMU_Task.c ****  */
