   1:Application/Src/IMU_Task.c **** /**
   2:Application/Src/IMU_Task.c ****  *******************************************************************************
   3:Application/Src/IMU_Task.c ****  * @file        IMU_Task.c
   4:Application/Src/IMU_Task.c ****  * @brief       IMU姿态解算任务 - 实现
   5:Application/Src/IMU_Task.c ****  * @details     基于Mahony互补滤波器的IMU姿态解算方案
   6:Application/Src/IMU_Task.c ****  *
   7:Application/Src/IMU_Task.c ****  *  系统工作流程
   8:Application/Src/IMU_Task.c ****  *  ============
   9:Application/Src/IMU_Task.c ****  *  1. 上电 → IMU_Init() 初始化PID、启动PWM加热、等待传感器就绪
  10:Application/Src/IMU_Task.c ****  *  2. 以 1kHz 循环执行：
  11:Application/Src/IMU_Task.c ****  *     a) IMU_temp_Ctrl()       — 每 300ms 一次温度PID控制
  12:Application/Src/IMU_Task.c ****  *     b) Gyro_Init()           — 前 1000ms 采集零偏均值
  13:Application/Src/IMU_Task.c ****  *     c) IMU_Data_Read()       — 读取传感器 → 减零偏 → Mahony解算姿态角
  14:Application/Src/IMU_Task.c ****  *  3. 校准完成后，roll/pitch/yaw 姿态角开始更新
  15:Application/Src/IMU_Task.c ****  *
  16:Application/Src/IMU_Task.c ****  *  关键数据结构
  17:Application/Src/IMU_Task.c ****  *  ============
  18:Application/Src/IMU_Task.c ****  *  - IMU_Data:    存储加速度、陀螺仪、温度、姿态角（roll/pitch/yaw）
  19:Application/Src/IMU_Task.c ****  *  - MahonyAHRS:  Mahony互补滤波器状态（四元数 + 中间变量）
  20:Application/Src/IMU_Task.c ****  *  - gyro_init:   陀螺仪三轴零偏值，校准完成后不再变化
  21:Application/Src/IMU_Task.c ****  *  - pid_temp:    温度PID控制器实例
  22:Application/Src/IMU_Task.c ****  *******************************************************************************
  23:Application/Src/IMU_Task.c ****  */
  24:Application/Src/IMU_Task.c **** #include "IMU_Task.h"
  25:Application/Src/IMU_Task.c **** 
  26:Application/Src/IMU_Task.c **** /*============================================================================
  27:Application/Src/IMU_Task.c ****  * 陀螺仪校准状态宏
  28:Application/Src/IMU_Task.c ****  *============================================================================*/
  29:Application/Src/IMU_Task.c **** #define Gyro_Init_Flag 0    /**< 校准中：累加原始数据计算零偏均值       */
  30:Application/Src/IMU_Task.c **** #define Gyro_Read_Flag 1    /**< 校准完成：正常运行，使用修正后数据     */
  31:Application/Src/IMU_Task.c **** 
ARM GAS  C:\Users\11464\AppData\Local\Temp\ccbN37mA.s 			page 2


  32:Application/Src/IMU_Task.c **** /*============================================================================
