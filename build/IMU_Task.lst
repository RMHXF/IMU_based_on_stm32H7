  61:Application/Src/IMU_Task.c **** uint8_t Init_Status = Gyro_Init_Flag;   /**< 陀螺仪校准状态，初值为"校准中" */
  62:Application/Src/IMU_Task.c **** 
  63:Application/Src/IMU_Task.c **** /**
  64:Application/Src/IMU_Task.c ****  *******************************************************************************
  65:Application/Src/IMU_Task.c ****  * @brief       IMU_Task - IMU主任务（RTOS线程入口）
  66:Application/Src/IMU_Task.c ****  * @param       argument  RTOS线程参数（未使用）
  67:Application/Src/IMU_Task.c ****  * @retval      void
  68:Application/Src/IMU_Task.c ****  * @details     上电初始化后以1kHz频率循环执行温控、零偏校准和姿态解算。
  69:Application/Src/IMU_Task.c ****  *              校准完成后（~1秒）姿态角开始正常输出。
  70:Application/Src/IMU_Task.c ****  *******************************************************************************
  71:Application/Src/IMU_Task.c ****  */
  72:Application/Src/IMU_Task.c **** void IMU_Task(void *argument)
  73:Application/Src/IMU_Task.c **** {
  74:Application/Src/IMU_Task.c ****     IMU_Init();                             /* 传感器及外设初始化              */
  75:Application/Src/IMU_Task.c ****     while (1)
  76:Application/Src/IMU_Task.c ****     {
  77:Application/Src/IMU_Task.c ****         osDelay(1);                         /* 1ms 周期 = 1kHz 控制/解算频率  */
  78:Application/Src/IMU_Task.c ****         IMU_temp_Ctrl();                    /* 温度PID控制（内部300ms分频）    */
  79:Application/Src/IMU_Task.c ****         IMU_Data_Read();                    /* 读取传感器 + Mahony姿态解算    */
  80:Application/Src/IMU_Task.c ****         Gyro_Init(&Init_Status);            /* 陀螺仪零偏校准状态机           */
  81:Application/Src/IMU_Task.c ****     }
  82:Application/Src/IMU_Task.c **** }
  83:Application/Src/IMU_Task.c **** 
