{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Download",
			"type": "shell",
			"command": "openocd",
			"args": [
				"-f",
				"D:/ec_env/OpenOCD/share/openocd/scripts/interface/cmsis-dap.cfg",
				"-f", //选择下载器
				"D:/ec_env/OpenOCD/share/openocd/scripts/target/stm32h7x.cfg",
				"-c", //选择芯片型号
				"program build/IMU.hex verify reset exit"
				//build文件夹下的XXX.hex文件
			],
			"problemMatcher": [
				"$gcc"
			],
			"group": {
                "kind": "build",
                "isDefault": true
            }
		}
	]
}